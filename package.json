{
  "name": "volttype",
  "version": "1.0.0",
  "description": "VoltType — AI-powered voice typing that learns your style",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js --dev",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:portable": "electron-builder --win portable",
    "setup-model": "node scripts/download-model.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:ui && npm run test:perf",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run tests/unit tests/integration --coverage",
    "test:ui": "playwright test",
    "test:perf": "node tests/performance/run-performance.js",
    "test:lighthouse": "node tests/performance/run-lighthouse.js"
  },
  "author": "Djoko",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@lhci/cli": "^0.15.1",
    "autocannon": "^8.0.0",
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1",
    "msw": "^2.11.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "com.volttype.app",
    "productName": "VoltType",
    "publish": {
      "provider": "github",
      "owner": "chrchevdj",
      "repo": "volttype-releases"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "VoltType",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
