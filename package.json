{
  "name": "volttype",
  "version": "1.0.0",
  "description": "VoltType — AI-powered voice typing that learns your style",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js --dev",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "setup-model": "node scripts/download-model.js"
  },
  "author": "Djoko",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.volttype.app",
    "productName": "VoltType",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5"
  }
}
